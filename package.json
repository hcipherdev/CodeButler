{
  "name": "code-butler",
  "version": "0.1.0",
  "description": "Local-first Project Memory MCP server for reconstructing project reasoning.",
  "type": "module",
  "bin": {
    "code-butler": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:public-sync": "node --test public-sync/tests/sync-public-repo.test.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "serve": "node dist/server.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
