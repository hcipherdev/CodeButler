{
  "name": "code-butler",
  "version": "1.0.0",
  "description": "Local-first Project Memory MCP server for reconstructing project reasoning.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hcipherdev/CodeButler.git"
  },
  "bugs": {
    "url": "https://github.com/hcipherdev/CodeButler/issues"
  },
  "homepage": "https://github.com/hcipherdev/CodeButler#readme",
  "keywords": [
    "mcp",
    "codex",
    "claude",
    "project-memory",
    "local-first",
    "agent-memory",
    "developer-tools"
  ],
  "files": [
    "dist"
  ],
  "bin": {
    "code-butler": "./dist/cli.js"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "docs:dev": "vitepress docs --host 127.0.0.1",
    "docs:build": "vitepress build docs",
    "serve": "node dist/server.js",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.0"
  }
}
